{{!
    @template local_aceengine/dashboard

    ACE Dashboard template.

    Displays score cards, XP/level progress, and active quests for the user.

    Context variables required for this template:
    * engagementscore - Engagement score percentage (0-100)
    * masteryscore - Mastery score percentage (0-100)
    * xp - Total XP earned
    * level - Current level number
    * levelprogress - Level progress percentage (0.0-100.0)
    * hasactivequests - Boolean indicating if there are active quests
    * activequests - Array of quest card data
    * completedcount - Number of completed quests
    * courseid - The course ID

    Example context (json):
    {
        "engagementscore": 75,
        "masteryscore": 62,
        "xp": 450,
        "level": 3,
        "levelprogress": 45.0,
        "hasactivequests": true,
        "activequests": [
            {
                "id": 1,
                "title": "Complete Quiz 1",
                "description": "Finish the chapter 1 quiz",
                "questtype": "quiz",
                "questtypelabel": "Quiz challenge",
                "xpreward": 50,
                "difficulty": 2,
                "difficultystars": [{"filled": true}, {"filled": true}, {"filled": false}],
                "isactive": true,
                "iscompleted": false,
                "isexpired": false,
                "expirydisplay": "23 hours"
            }
        ],
        "completedcount": 12,
        "courseid": 2
    }
}}
<div class="local-ace-dashboard" data-courseid="{{courseid}}">

    {{! Score cards row }}
    <div class="row mb-4">
        <div class="col-sm-6 col-lg-3 mb-3">
            <div class="card local-ace-score-card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">{{#str}}engagementscore, local_aceengine{{/str}}</h5>
                    <div class="local-ace-score-value display-4">{{engagementscore}}%</div>
                    <div class="progress mt-2 local-ace-progress">
                        <div class="progress-bar bg-primary" role="progressbar"
                             style="width: {{engagementscore}}%"
                             aria-valuenow="{{engagementscore}}" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-3">
            <div class="card local-ace-score-card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">{{#str}}masteryscore, local_aceengine{{/str}}</h5>
                    <div class="local-ace-score-value display-4">{{masteryscore}}%</div>
                    <div class="progress mt-2 local-ace-progress">
                        <div class="progress-bar bg-success" role="progressbar"
                             style="width: {{masteryscore}}%"
                             aria-valuenow="{{masteryscore}}" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-3">
            <div class="card local-ace-score-card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">{{#str}}totalxp, local_aceengine{{/str}}</h5>
                    <div class="local-ace-score-value display-4">{{xp}}</div>
                    <small class="text-muted">{{#str}}xp_label, local_aceengine{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3 mb-3">
            <div class="card local-ace-score-card h-100">
                <div class="card-body text-center">
                    <h5 class="card-title text-muted">{{#str}}level, local_aceengine{{/str}}</h5>
                    <div class="local-ace-score-value display-4">{{level}}</div>
                    <div class="progress mt-2 local-ace-progress">
                        <div class="progress-bar bg-warning" role="progressbar"
                             style="width: {{levelprogress}}%"
                             aria-valuenow="{{levelprogress}}" aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                    <small class="text-muted">{{levelprogress}}%</small>
                </div>
            </div>
        </div>
    </div>

    {{! Active quests section }}
    <div class="local-ace-quests-section mb-4">
        <h3 class="mb-3">{{#str}}activequests, local_aceengine{{/str}}</h3>
        {{#hasactivequests}}
            <div class="row">
                {{#activequests}}
                    <div class="col-md-6 col-lg-4 mb-3">
                        {{> local_aceengine/quest_card}}
                    </div>
                {{/activequests}}
            </div>
        {{/hasactivequests}}
        {{^hasactivequests}}
            <div class="alert alert-info">
                {{#str}}noactivequests, local_aceengine{{/str}}
            </div>
        {{/hasactivequests}}
    </div>

    {{! Recommended activities (Pro feature) }}
    {{#hasrecommendations}}
    <div class="local-ace-recommendations-section mb-4">
        <h3 class="mb-3">{{#str}}recommendations_title, local_aceengine{{/str}} <span class="badge badge-info">{{#str}}pro_badge, local_aceengine{{/str}}</span></h3>
        <div class="list-group">
            {{#recommendations}}
            <a href="{{url}}" class="list-group-item list-group-item-action d-flex align-items-center">
                <img src="{{iconurl}}" alt="" class="mr-3 local-ace-rec-icon">
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong>{{name}}</strong>
                        {{#islowgrade}}
                        <span class="badge badge-warning ml-2">{{#str}}rec_needs_improvement, local_aceengine{{/str}}</span>
                        {{/islowgrade}}
                    </div>
                    <small class="text-muted">{{section}} &middot; {{reason}}</small>
                </div>
                <i class="fa fa-chevron-right ml-2 text-muted"></i>
            </a>
            {{/recommendations}}
        </div>
    </div>
    {{/hasrecommendations}}

    {{! AI Content Suggestions (Pro feature) }}
    {{#hascontentsuggestions}}
    <div class="local-ace-content-suggestions-section mb-4">
        <h3 class="mb-3">
            <i class="fa fa-lightbulb-o text-success"></i>
            {{#str}}content_suggestions_student_title, local_aceengine{{/str}}
            <span class="badge badge-info">{{#str}}pro_badge, local_aceengine{{/str}}</span>
        </h3>
        <div class="list-group">
            {{#contentsuggestions}}
            <div class="list-group-item">
                <div class="d-flex align-items-start">
                    <div class="mr-3 text-center" style="min-width: 40px;">
                        <i class="fa {{type_icon}} fa-2x text-{{type_class}}"></i>
                        <br><small class="text-muted">{{type_label}}</small>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center mb-1">
                            <strong>{{title}}</strong>
                            {{#platform}}
                            <span class="badge badge-light ml-2">{{platform}}</span>
                            {{/platform}}
                            {{#estimated_minutes}}
                            <small class="text-muted ml-auto"><i class="fa fa-clock-o"></i> ~{{estimated_minutes}}min</small>
                            {{/estimated_minutes}}
                        </div>
                        <p class="mb-1 text-muted small">{{description}}</p>
                        {{#relevance}}
                        <p class="mb-1 small"><em class="text-info"><i class="fa fa-lightbulb-o"></i> {{relevance}}</em></p>
                        {{/relevance}}
                        <div class="mt-1">
                            {{#has_url}}
                            <a href="{{url}}" target="_blank" class="btn btn-sm btn-primary" rel="noopener noreferrer">
                                <i class="fa fa-external-link"></i> {{#str}}content_suggestions_visit, local_aceengine{{/str}}
                            </a>
                            {{/has_url}}
                            {{^has_url}}
                                {{#search_url}}
                                <a href="{{search_url}}" target="_blank" class="btn btn-sm btn-outline-primary" rel="noopener noreferrer">
                                    <i class="fa fa-search"></i> {{#str}}content_suggestions_search, local_aceengine{{/str}}
                                </a>
                                {{/search_url}}
                            {{/has_url}}
                        </div>
                    </div>
                </div>
            </div>
            {{/contentsuggestions}}
        </div>
        {{#contentsuggestiondate}}
        <small class="text-muted mt-2 d-block">
            {{#str}}content_suggestions_generated, local_aceengine{{/str}} {{contentsuggestiondate}}
        </small>
        {{/contentsuggestiondate}}
    </div>
    {{/hascontentsuggestions}}

    {{! AI Learning Path (Pro feature) }}
    {{#haslearningpath}}
    <div class="local-ace-learning-path-section mb-4">
        <h3 class="mb-3">
            <i class="fa fa-road text-primary"></i>
            {{#str}}learning_path_student_title, local_aceengine{{/str}}
            <span class="badge badge-info">{{#str}}pro_badge, local_aceengine{{/str}}</span>
        </h3>
        {{#learningpathsummary}}
        <div class="alert alert-light border mb-3">
            <i class="fa fa-info-circle text-primary"></i> {{learningpathsummary}}
        </div>
        {{/learningpathsummary}}
        {{#learningpathhours}}
        <p class="text-muted small mb-3">
            <i class="fa fa-clock-o"></i> {{#str}}learning_path_estimated, local_aceengine{{/str}} <strong>{{learningpathhours}}h</strong>
        </p>
        {{/learningpathhours}}
        <div class="list-group">
            {{#learningpathsteps}}
            <div class="list-group-item">
                <div class="d-flex align-items-start">
                    <div class="mr-3 text-center" style="min-width: 40px;">
                        <span class="badge badge-pill badge-primary" style="font-size: 1.1em;">{{order}}</span>
                        <br><i class="fa {{type_icon}} text-muted mt-1"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center mb-1">
                            {{#has_url}}
                            <a href="{{activity_url}}" class="font-weight-bold text-decoration-none">
                                {{title}} <i class="fa fa-external-link small"></i>
                            </a>
                            {{/has_url}}
                            {{^has_url}}
                            <strong>{{title}}</strong>
                            {{/has_url}}
                            <span class="badge badge-{{priority_class}} ml-2">{{priority_label}}</span>
                            {{#estimated_minutes}}
                            <small class="text-muted ml-auto"><i class="fa fa-clock-o"></i> ~{{estimated_minutes}}min</small>
                            {{/estimated_minutes}}
                        </div>
                        <p class="mb-1 text-muted small">{{description}}</p>
                        {{#reason}}
                        <p class="mb-0 small"><em class="text-info"><i class="fa fa-lightbulb-o"></i> {{#str}}learning_path_why, local_aceengine{{/str}} {{reason}}</em></p>
                        {{/reason}}
                        {{#section_hint}}
                        <small class="text-muted"><i class="fa fa-bookmark-o"></i> {{section_hint}}</small>
                        {{/section_hint}}
                    </div>
                </div>
            </div>
            {{/learningpathsteps}}
        </div>
        {{#learningpathdate}}
        <small class="text-muted mt-2 d-block">
            {{#str}}learning_path_generated, local_aceengine{{/str}} {{learningpathdate}}
        </small>
        {{/learningpathdate}}
    </div>
    {{/haslearningpath}}

    {{! Completed quests summary }}
    <div class="local-ace-completed-section">
        <div class="card">
            <div class="card-body d-flex align-items-center">
                <span class="mr-2"><strong>{{#str}}completedquests, local_aceengine{{/str}}:</strong></span>
                <span class="badge badge-success badge-pill local-ace-completed-badge">{{completedcount}}</span>
            </div>
        </div>
    </div>

</div>
