{{!
    @template local_aceengine/my_quests

    My Quests page template.

    Displays all quests across all courses, grouped by course,
    with a summary bar and collapsible course sections.

    Context variables required for this template:
    * courses - Array of course objects with quest data
    * hascourses - Whether there are any courses with quests
    * totalactivequests - Total active quests across all courses
    * totalcompletedquests - Total completed quests across all courses
    * totalxp - Total XP across all courses
}}
<div class="local-ace-myquests">

    {{! Summary bar }}
    <div class="row mb-4">
        <div class="col-md-4 mb-2">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="h3 mb-0 text-warning font-weight-bold">{{totalxp}}</div>
                    <small class="text-muted">{{#str}}totalxp, local_aceengine{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-2">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="h3 mb-0 text-primary font-weight-bold">{{totalactivequests}}</div>
                    <small class="text-muted">{{#str}}activequests, local_aceengine{{/str}}</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-2">
            <div class="card text-center">
                <div class="card-body py-3">
                    <div class="h3 mb-0 text-success font-weight-bold">{{totalcompletedquests}}</div>
                    <small class="text-muted">{{#str}}completedquests, local_aceengine{{/str}}</small>
                </div>
            </div>
        </div>
    </div>

    {{^hascourses}}
        <div class="alert alert-info text-center">
            {{#str}}noquestsyet, local_aceengine{{/str}}
        </div>
    {{/hascourses}}

    {{#hascourses}}
        <div class="accordion" id="aceMyQuestsAccordion">
            {{#courses}}
                <div class="card mb-3">
                    {{! Course header }}
                    <div class="card-header d-flex align-items-center justify-content-between"
                         id="heading-course-{{courseid}}"
                         data-toggle="collapse"
                         data-target="#collapse-course-{{courseid}}"
                         aria-expanded="true"
                         aria-controls="collapse-course-{{courseid}}"
                         role="button">
                        <div class="d-flex align-items-center flex-wrap">
                            <h5 class="mb-0 mr-3">
                                <a href="{{courseurl}}" class="text-dark local-ace-course-link">{{coursename}}</a>
                            </h5>
                            <span class="badge badge-warning mr-2">{{xp}} {{#str}}xp_label, local_aceengine{{/str}}</span>
                            <span class="badge badge-info mr-2">{{#str}}level, local_aceengine{{/str}} {{level}}</span>
                            {{#hasactivequests}}
                                <span class="badge badge-primary mr-2">{{activequestcount}} {{#str}}activequests, local_aceengine{{/str}}</span>
                            {{/hasactivequests}}
                            {{#hascompletedquests}}
                                <span class="badge badge-success">{{completedquestcount}} {{#str}}completedquests, local_aceengine{{/str}}</span>
                            {{/hascompletedquests}}
                        </div>
                        <i class="fa fa-chevron-down" aria-hidden="true"></i>
                    </div>

                    <div id="collapse-course-{{courseid}}" class="collapse show"
                         aria-labelledby="heading-course-{{courseid}}">
                        <div class="card-body">
                            {{! Active quests section }}
                            {{#hasactivequests}}
                                <h6 class="text-primary mb-3">
                                    <i class="fa fa-bolt" aria-hidden="true"></i>
                                    {{#str}}activequests, local_aceengine{{/str}} ({{activequestcount}})
                                </h6>
                                <div class="row">
                                    {{#activequests}}
                                        <div class="col-md-6 col-lg-4 mb-3">
                                            {{> local_aceengine/quest_card}}
                                        </div>
                                    {{/activequests}}
                                </div>
                            {{/hasactivequests}}

                            {{! Completed quests section }}
                            {{#hascompletedquests}}
                                <div class="mt-3">
                                    <h6 class="text-success mb-3" data-toggle="collapse"
                                        data-target="#completed-course-{{courseid}}"
                                        role="button">
                                        <i class="fa fa-check-circle" aria-hidden="true"></i>
                                        {{#str}}completedquests, local_aceengine{{/str}} ({{completedquestcount}})
                                        <i class="fa fa-chevron-down ml-1" aria-hidden="true"></i>
                                    </h6>
                                    <div id="completed-course-{{courseid}}" class="collapse">
                                        <div class="row">
                                            {{#completedquests}}
                                                <div class="col-md-6 col-lg-4 mb-3">
                                                    {{> local_aceengine/quest_card}}
                                                </div>
                                            {{/completedquests}}
                                        </div>
                                    </div>
                                </div>
                            {{/hascompletedquests}}

                            {{! Link to course dashboard }}
                            <div class="mt-2 text-right">
                                <a href="{{dashboardurl}}" class="btn btn-outline-primary btn-sm">
                                    {{#str}}dashboard, local_aceengine{{/str}}
                                    <i class="fa fa-arrow-right ml-1" aria-hidden="true"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/courses}}
        </div>
    {{/hascourses}}
</div>
